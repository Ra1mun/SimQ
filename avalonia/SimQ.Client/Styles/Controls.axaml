<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Primary action button (accent) -->
  <Style Selector="Button.primary">
    <Setter Property="Foreground" Value="{StaticResource AccentFgBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="12,0"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.primary /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource AccentFgBrush}"/>
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#3554B8"/>
    <Setter Property="BorderBrush" Value="#3554B8"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource AccentFgBrush}"/>
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#2E48A0"/>
    <Setter Property="BorderBrush" Value="#2E48A0"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource AccentFgBrush}"/>
  </Style>

  <!-- Secondary button -->
  <Style Selector="Button.secondary">
    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="26"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="Medium"/>
  </Style>
  <Style Selector="Button.secondary /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgBrush}"/>
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
  </Style>

  <!-- Toolbar / icon button -->
  <Style Selector="Button.toolbar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="CornerRadius" Value="5"/>
    <Setter Property="Padding" Value="10,0"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
  </Style>
  <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="5"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Width" Value="28"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
  </Style>

  <!-- Card container -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="14"/>
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox.simq">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="MinHeight" Value="26"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox.simq">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="MinHeight" Value="26"/>
    <Setter Property="FontSize" Value="12"/>
  </Style>

  <!-- Tab button (top tabs row) -->
  <Style Selector="Button.tab">
    <Setter Property="Padding" Value="14,6,14,7"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Foreground" Value="{StaticResource FgMuteBrush}"/>
    <Setter Property="Margin" Value="0,0,2,-1"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.tab /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1,1,1,0"/>
    <Setter Property="CornerRadius" Value="5,5,0,0"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgMuteBrush}"/>
  </Style>
  <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgBrush}"/>
  </Style>
  <Style Selector="Button.tab.active /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgBrush}"/>
  </Style>
  <Style Selector="Button.tab.active:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
  </Style>
  <Style Selector="Button.tab.active">
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
  </Style>

  <!-- Nav rail item -->
  <Style Selector="ToggleButton.nav">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="48"/>
    <Setter Property="Height" Value="44"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Foreground" Value="{StaticResource FgMuteBrush}"/>
  </Style>
  <Style Selector="ToggleButton.nav:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
  </Style>
  <Style Selector="ToggleButton.nav:checked">
    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <!-- Win11 caption buttons -->
  <Style Selector="Button.caption">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="0"/>
    <Setter Property="Width" Value="46"/>
    <Setter Property="Height" Value="32"/>
  </Style>
  <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1A000000"/>
  </Style>
  <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#E81123"/>
    <Setter Property="TextElement.Foreground" Value="White"/>
  </Style>

  <!-- Status badge -->
  <Style Selector="Border.badge">
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="6,2"/>
  </Style>

  <!-- Disabled visuals so a non-clickable button reads as such -->
  <Style Selector="Button.primary:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Panel3Brush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgDimBrush}"/>
  </Style>
  <Style Selector="Button.secondary:disabled /template/ ContentPresenter">
    <Setter Property="TextElement.Foreground" Value="{StaticResource FgDimBrush}"/>
  </Style>
</Styles>
