<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimQ.Client.ViewModels"
             xmlns:conv="using:SimQ.Client.Converters"
             x:Class="SimQ.Client.Views.SimulateView"
             x:DataType="vm:MainViewModel">
  <ScrollViewer>
    <Grid ColumnDefinitions="*,360" Margin="20" >
      <!-- Left: control card -->
      <StackPanel Grid.Column="0" Spacing="16" Margin="0,0,16,0">
        <Border Classes="card">
          <StackPanel Spacing="14">
            <StackPanel Spacing="3">
              <TextBlock Classes="section-header" Text="ТЕКУЩАЯ ЗАДАЧА"/>
              <TextBlock Text="{Binding CurrentProblem.Name}" Classes="h2"/>
              <TextBlock Text="{Binding CurrentProblem.Description}" Classes="dim"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,16,*">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Classes="section-header" Text="КОЛ-ВО ИТЕРАЦИЙ"/>
                <NumericUpDown Value="{Binding Iterations, Mode=TwoWay}" Minimum="1000" Increment="1000"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Classes="section-header" Text="SEED"/>
                <NumericUpDown Value="{Binding Seed, Mode=TwoWay}"/>
              </StackPanel>
            </Grid>

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="ПРОГРЕСС" Classes="section-header"/>
                <TextBlock Grid.Column="1" Classes="mono" FontSize="11"
                           Foreground="{StaticResource AccentBrush}">
                  <Run Text="{Binding ProgressPercent}"/><Run Text=" %"/>
                </TextBlock>
              </Grid>
              <Border Height="10" CornerRadius="5" Background="{StaticResource Panel2Brush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                <Border HorizontalAlignment="Left" CornerRadius="5"
                        Background="{StaticResource AccentBrush}"
                        Width="{Binding Progress, Converter={x:Static conv:ProgressToWidthConverter.Instance}, ConverterParameter=580}"/>
              </Border>
              <TextBlock Text="{Binding IterationsLabel}" Classes="mono dim" FontSize="11"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="primary" Content="▶  Запустить"
                      Command="{Binding StartSimulationCommand}"
                      IsEnabled="{Binding !IsRunning}"/>
              <Button Classes="secondary" Content="■  Остановить"
                      Command="{Binding StopSimulationCommand}"
                      IsEnabled="{Binding IsRunning}"/>
              <Button Classes="secondary" Content="📊 Открыть результаты"
                      Command="{Binding OpenResultsCommand}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="card" Padding="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
              <TextBlock Text="ЛОГ ИСПОЛНЕНИЯ" Classes="section-header"/>
            </Border>
            <Border Background="{StaticResource LogBgBrush}" CornerRadius="0,0,6,6">
              <ScrollViewer MaxHeight="220">
                <StackPanel Margin="10,8" Spacing="3">
                  <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource LogFgBrush}">
                    <Run Text="[12:30:01] " Foreground="#88AABB"/><Run Text="info " Foreground="#6CB6FF"/><Run Text="prepare workspace"/>
                  </TextBlock>
                  <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource LogFgBrush}">
                    <Run Text="[12:30:02] " Foreground="#88AABB"/><Run Text="info " Foreground="#6CB6FF"/><Run Text="POST /Modeling/v1/start → 202 Accepted"/>
                  </TextBlock>
                  <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource LogFgBrush}">
                    <Run Text="[12:30:09] " Foreground="#88AABB"/><Run Text="ok   " Foreground="#7BD389"/><Run Text="warm-up complete (5 000 / 50 000)"/>
                  </TextBlock>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </DockPanel>
        </Border>
      </StackPanel>

      <!-- Right: side stats -->
      <StackPanel Grid.Column="1" Spacing="12">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-header" Text="МЕТРИКИ ИСПОЛНЕНИЯ"/>
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" >
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                <TextBlock Text="Пропускная" FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
                <TextBlock Text="0.842" Classes="mono" FontSize="20" FontWeight="SemiBold"/>
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                <TextBlock Text="Загрузка ρ" FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
                <TextBlock Text="0.71" Classes="mono" FontSize="20" FontWeight="SemiBold"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                <TextBlock Text="Среднее t_w" FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
                <TextBlock Text="3.21 c" Classes="mono" FontSize="20" FontWeight="SemiBold"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                <TextBlock Text="P отказа" FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
                <TextBlock Text="0.064" Classes="mono" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource WarnBrush}"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
        <Border Classes="card">
          <StackPanel Spacing="6">
            <TextBlock Classes="section-header" Text="ПОДКЛЮЧЕНИЕ"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="7" Height="7"
                       Fill="{Binding IsApiOnline, Converter={x:Static conv:BoolToOnlineBrushConverter.Instance}}"/>
              <TextBlock Text="SimQ.WebApi" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding ApiBaseUrl}" Classes="mono dim"/>
            </StackPanel>
            <TextBlock Text="{Binding ApiStatusText}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding CurrentTaskId, StringFormat='task: {0}'}" Classes="mono dim" FontSize="11"
                       IsVisible="{Binding CurrentTaskId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
