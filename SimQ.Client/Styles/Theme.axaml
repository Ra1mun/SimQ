<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <!-- SimQ palette — cool-neutral, CAD-ish. Mirrors :root tokens from
           the HTML prototype so AXAML and CSS stay in sync. -->
      <Color  x:Key="SimQ.Bg">#FAFBFC</Color>
      <Color  x:Key="SimQ.Panel">#F2F4F7</Color>
      <Color  x:Key="SimQ.Panel2">#E9ECF1</Color>
      <Color  x:Key="SimQ.Panel3">#DFE3EA</Color>
      <Color  x:Key="SimQ.Fg">#262A33</Color>
      <Color  x:Key="SimQ.FgMute">#5C6371</Color>
      <Color  x:Key="SimQ.FgDim">#828998</Color>
      <Color  x:Key="SimQ.Border">#D8DCE3</Color>
      <Color  x:Key="SimQ.BorderStrong">#B8BEC8</Color>
      <Color  x:Key="SimQ.Accent">#3D5FCC</Color>
      <Color  x:Key="SimQ.AccentSoft">#E5EAFA</Color>
      <Color  x:Key="SimQ.AccentFg">#FFFFFF</Color>
      <Color  x:Key="SimQ.Ok">#2D8A4F</Color>
      <Color  x:Key="SimQ.Warn">#B07A1A</Color>
      <Color  x:Key="SimQ.Err">#C53030</Color>
      <Color  x:Key="SimQ.TitleBar">#E2E5EB</Color>
      <Color  x:Key="SimQ.CanvasBg">#F7F8FB</Color>
      <Color  x:Key="SimQ.CanvasGrid">#CDD2DB</Color>
      <Color  x:Key="SimQ.LogBg">#1A1D23</Color>
      <Color  x:Key="SimQ.LogFg">#DADFE6</Color>

      <!-- Agent kind swatches -->
      <Color  x:Key="SimQ.Source">#C99A2E</Color>
      <Color  x:Key="SimQ.ServiceBlock">#3D5FCC</Color>
      <Color  x:Key="SimQ.Buffer">#3F9C68</Color>
      <Color  x:Key="SimQ.Orbit">#9447A6</Color>
      <Color  x:Key="SimQ.Sink">#7A7E89</Color>

      <!-- Brushes -->
      <SolidColorBrush x:Key="BgBrush"          Color="{StaticResource SimQ.Bg}"/>
      <SolidColorBrush x:Key="PanelBrush"       Color="{StaticResource SimQ.Panel}"/>
      <SolidColorBrush x:Key="Panel2Brush"      Color="{StaticResource SimQ.Panel2}"/>
      <SolidColorBrush x:Key="Panel3Brush"      Color="{StaticResource SimQ.Panel3}"/>
      <SolidColorBrush x:Key="FgBrush"          Color="{StaticResource SimQ.Fg}"/>
      <SolidColorBrush x:Key="FgMuteBrush"      Color="{StaticResource SimQ.FgMute}"/>
      <SolidColorBrush x:Key="FgDimBrush"       Color="{StaticResource SimQ.FgDim}"/>
      <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource SimQ.Border}"/>
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource SimQ.BorderStrong}"/>
      <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource SimQ.Accent}"/>
      <SolidColorBrush x:Key="AccentSoftBrush"  Color="{StaticResource SimQ.AccentSoft}"/>
      <SolidColorBrush x:Key="AccentFgBrush"    Color="{StaticResource SimQ.AccentFg}"/>
      <SolidColorBrush x:Key="OkBrush"          Color="{StaticResource SimQ.Ok}"/>
      <SolidColorBrush x:Key="WarnBrush"        Color="{StaticResource SimQ.Warn}"/>
      <SolidColorBrush x:Key="ErrBrush"         Color="{StaticResource SimQ.Err}"/>
      <SolidColorBrush x:Key="TitleBarBrush"    Color="{StaticResource SimQ.TitleBar}"/>
      <SolidColorBrush x:Key="CanvasBgBrush"    Color="{StaticResource SimQ.CanvasBg}"/>
      <SolidColorBrush x:Key="CanvasGridBrush"  Color="{StaticResource SimQ.CanvasGrid}"/>
      <SolidColorBrush x:Key="LogBgBrush"       Color="{StaticResource SimQ.LogBg}"/>
      <SolidColorBrush x:Key="LogFgBrush"       Color="{StaticResource SimQ.LogFg}"/>

      <SolidColorBrush x:Key="SourceBrush"        Color="{StaticResource SimQ.Source}"/>
      <SolidColorBrush x:Key="ServiceBlockBrush"  Color="{StaticResource SimQ.ServiceBlock}"/>
      <SolidColorBrush x:Key="BufferBrush"        Color="{StaticResource SimQ.Buffer}"/>
      <SolidColorBrush x:Key="OrbitBrush"         Color="{StaticResource SimQ.Orbit}"/>
      <SolidColorBrush x:Key="SinkBrush"          Color="{StaticResource SimQ.Sink}"/>

      <!-- Typography -->
      <FontFamily x:Key="UiFont">Inter, Segoe UI, sans-serif</FontFamily>
      <FontFamily x:Key="MonoFont">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>
    </ResourceDictionary>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
  </Style>

  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
  </Style>

  <Style Selector="TextBlock.dim">
    <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
  </Style>

  <Style Selector="TextBlock.mute">
    <Setter Property="Foreground" Value="{StaticResource FgMuteBrush}"/>
  </Style>

  <Style Selector="TextBlock.section-header">
    <Setter Property="FontSize" Value="10.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource FgMuteBrush}"/>
    <Setter Property="LetterSpacing" Value="1.2"/>
  </Style>

  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
</Styles>
