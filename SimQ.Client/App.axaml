<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SimQ.Client.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://SimQ.Client/Styles/Theme.axaml"/>
    <StyleInclude Source="avares://SimQ.Client/Styles/Controls.axaml"/>
  </Application.Styles>
</Application>
