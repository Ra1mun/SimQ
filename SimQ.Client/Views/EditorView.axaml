<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimQ.Client.ViewModels"
             xmlns:m="using:SimQ.Client.Models"
             xmlns:conv="using:SimQ.Client.Converters"
             x:Class="SimQ.Client.Views.EditorView"
             x:DataType="vm:MainViewModel"
             Focusable="True">
  <Grid ColumnDefinitions="240,*,300">

    <!-- LEFT: problem list -->
    <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="12,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <StackPanel Spacing="6">
            <TextBlock Classes="section-header" Text="ЗАДАЧИ"/>
            <TextBox Classes="simq" Watermark="Поиск..." Text="{Binding ProblemSearchQuery, Mode=TwoWay}"/>
          </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Padding="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
          <Button Classes="primary" HorizontalAlignment="Stretch" Content="＋  Новая задача"
                  Command="{Binding OpenWizardCommand}"/>
        </Border>
        <ListBox ItemsSource="{Binding FilteredProblems}" SelectedItem="{Binding CurrentProblem, Mode=TwoWay}"
                 Background="Transparent" BorderThickness="0" Padding="6">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ProblemViewModel">
              <Border Padding="10,8" CornerRadius="4">
                <StackPanel Spacing="3">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                    <Border Grid.Column="1" Classes="badge"
                            BorderBrush="{Binding Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}">
                      <TextBlock FontSize="9" FontWeight="SemiBold" LetterSpacing="0.8"
                                 Foreground="{Binding Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}"
                                 Text="{Binding Status, Converter={x:Static conv:ProblemStatusToLabelConverter.Instance}}"/>
                    </Border>
                  </Grid>
                  <TextBlock Text="{Binding Description}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding AgentsLabel}" Classes="mono dim" FontSize="10"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- CENTER: canvas -->
    <Grid Grid.Column="1" RowDefinitions="36,*">
      <!-- Toolstrip -->
      <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Margin="8,0" Spacing="2" VerticalAlignment="Center">
          <Button Classes="toolbar" Content="＋ SRC" ToolTip.Tip="Источник"
                  Command="{Binding AddAgentCommand}" CommandParameter="Source"/>
          <Button Classes="toolbar" Content="＋ SVB" ToolTip.Tip="Блок приборов"
                  Command="{Binding AddAgentCommand}" CommandParameter="ServiceBlock"/>
          <Button Classes="toolbar" Content="＋ BUF" ToolTip.Tip="Хранилище"
                  Command="{Binding AddAgentCommand}" CommandParameter="Buffer"/>
          <Button Classes="toolbar" Content="＋ ORB" ToolTip.Tip="Орбита"
                  Command="{Binding AddAgentCommand}" CommandParameter="Orbit"/>
          <Button Classes="toolbar" Content="＋ SNK" ToolTip.Tip="Сток"
                  Command="{Binding AddAgentCommand}" CommandParameter="Sink"/>
          <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="6,0"/>
          <Button Classes="toolbar" Content="↺"/>
          <Button Classes="toolbar" Content="↻"/>
          <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="6,0"/>
          <TextBlock Text="Масштаб" VerticalAlignment="Center" Foreground="{StaticResource FgMuteBrush}" FontSize="11" Margin="0,0,6,0"/>
          <TextBlock Text="{Binding Zoom, StringFormat='{}{0:P0}'}" Classes="mono" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Canvas -->
      <Border Grid.Row="1" ClipToBounds="True" Name="CanvasViewport">
        <Border.Background>
          <DrawingBrush TileMode="Tile" SourceRect="0,0,24,24" DestinationRect="0,0,24,24">
            <DrawingBrush.Drawing>
              <GeometryDrawing>
                <GeometryDrawing.Geometry>
                  <RectangleGeometry Rect="0,0,24,24"/>
                </GeometryDrawing.Geometry>
                <GeometryDrawing.Pen>
                  <Pen Brush="{StaticResource CanvasGridBrush}" Thickness="0.5"/>
                </GeometryDrawing.Pen>
              </GeometryDrawing>
            </DrawingBrush.Drawing>
          </DrawingBrush>
        </Border.Background>
        <Panel ClipToBounds="False">
          <Panel Name="GraphCanvas" ClipToBounds="False"
                 Width="40000" Height="40000"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 RenderTransformOrigin="0,0">

          <!-- Edges layer -->
          <ItemsControl ItemsSource="{Binding CurrentProblem.Edges}" ClipToBounds="False">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><Canvas ClipToBounds="False"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:Edge">
                <Panel>
                  <!-- Invisible thick line for easier clicking -->
                  <Line StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}"
                        Stroke="Transparent" StrokeThickness="12"
                        Cursor="Hand"
                        PointerPressed="OnEdgePointerPressed"/>
                  <!-- Visible line -->
                  <Line StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}"
                        Stroke="{StaticResource BorderStrongBrush}" StrokeThickness="1.5"
                        IsHitTestVisible="False"/>
                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Nodes -->
          <ItemsControl ItemsSource="{Binding CurrentProblem.Agents}" ClipToBounds="False">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><Canvas ClipToBounds="False"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:AgentViewModel">
                <Panel>
                  <Panel.RenderTransform>
                    <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                  </Panel.RenderTransform>

                  <!-- Main node body -->
                  <Border Width="140" Height="64" CornerRadius="6"
                          Background="White"
                          BorderBrush="{Binding Kind, Converter={x:Static conv:AgentKindToBrushConverter.Instance}}"
                          BorderThickness="1.5"
                          BoxShadow="0 2 6 0 #15000000"
                          PointerPressed="OnNodePointerPressed"
                          Cursor="Hand">
                    <Grid RowDefinitions="Auto,*" Margin="10,8">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="22" Height="14" CornerRadius="2"
                                Background="{Binding Kind, Converter={x:Static conv:AgentKindToBrushConverter.Instance}}">
                          <TextBlock Text="{Binding ShortLabel}" FontSize="8" FontWeight="Bold"
                                     FontFamily="{StaticResource MonoFont}"
                                     Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                      </StackPanel>
                      <TextBlock Grid.Row="1" Text="{Binding ParamsSummary}"
                                 Classes="mono dim" FontSize="10"
                                 VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </Border>

                  <!-- Left connector (input) -->
                  <Panel Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center"
                         Margin="-8,0,0,0" Cursor="Hand"
                         PointerPressed="OnInputConnectorPressed">
                    <Ellipse Width="12" Height="12" Fill="#3D5FCC" Stroke="White" StrokeThickness="2"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Panel.Styles>
                      <Style Selector="Panel:pointerover Ellipse">
                        <Setter Property="Width" Value="14"/>
                        <Setter Property="Height" Value="14"/>
                        <Setter Property="Fill" Value="#5577EE"/>
                      </Style>
                    </Panel.Styles>
                  </Panel>

                  <!-- Right connector (output) — start linking with right-click -->
                  <Panel Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,0,-8,0" Cursor="Hand"
                         PointerPressed="OnOutputConnectorPressed">
                    <Ellipse Width="12" Height="12" Fill="#3D5FCC" Stroke="White" StrokeThickness="2"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Small arrow indicator -->
                    <TextBlock Text="▶" FontSize="6" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0.5,0,0,0"/>
                    <Panel.Styles>
                      <Style Selector="Panel:pointerover Ellipse">
                        <Setter Property="Width" Value="14"/>
                        <Setter Property="Height" Value="14"/>
                        <Setter Property="Fill" Value="#5577EE"/>
                      </Style>
                    </Panel.Styles>
                  </Panel>
                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Link preview line (shown while dragging a connection) -->
          <Line Name="LinkPreviewLine" IsVisible="False"
                Stroke="#3D5FCC" StrokeThickness="2"
                StrokeDashArray="4,4" Opacity="0.7"/>
        </Panel>
        </Panel>
      </Border>


    </Grid>

    <!-- RIGHT: properties -->
    <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="14,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <StackPanel Spacing="2">
            <TextBlock Classes="section-header">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}">
                  <Binding Path="SelectedAgent" Converter="{x:Static ObjectConverters.IsNotNull}"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <!-- Agent header -->
            <StackPanel IsVisible="{Binding SelectedAgent, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="2">
              <TextBlock Classes="section-header" Text="СВОЙСТВА АГЕНТА"/>
              <TextBlock Text="{Binding SelectedAgent.Name}" FontWeight="SemiBold" FontSize="14"/>
              <TextBlock Text="{Binding SelectedAgent.KindLabel}" Classes="dim" FontSize="11"/>
            </StackPanel>
            <!-- Edge header -->
            <StackPanel IsVisible="{Binding SelectedEdge, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="2">
              <TextBlock Classes="section-header" Text="СВОЙСТВА СВЯЗИ"/>
              <TextBlock FontWeight="SemiBold" FontSize="14">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} → {1}">
                    <Binding Path="SelectedEdge.From"/>
                    <Binding Path="SelectedEdge.To"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="Связь между агентами" Classes="dim" FontSize="11"/>
            </StackPanel>
            <!-- Nothing selected -->
            <TextBlock Text="— ничего не выбрано —" FontWeight="SemiBold" FontSize="14">
              <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                  <Binding Path="SelectedAgent" Converter="{x:Static ObjectConverters.IsNull}"/>
                  <Binding Path="SelectedEdge" Converter="{x:Static ObjectConverters.IsNull}"/>
                </MultiBinding>
              </TextBlock.IsVisible>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Edge properties panel -->
        <ScrollViewer IsVisible="{Binding SelectedEdge, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Margin="14" Spacing="14">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="ИДЕНТИФИКАТОР"/>
              <TextBox Classes="simq" Text="{Binding SelectedEdge.Id, Mode=OneWay}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="ОТКУДА"/>
              <TextBox Classes="simq" Text="{Binding SelectedEdge.From, Mode=OneWay}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="КУДА"/>
              <TextBox Classes="simq" Text="{Binding SelectedEdge.To, Mode=OneWay}" IsReadOnly="True"/>
            </StackPanel>
            <Button Classes="secondary" HorizontalAlignment="Stretch" Content="🗑  Удалить связь"
                    Command="{Binding DeleteSelectedEdgeCommand}"/>
          </StackPanel>
        </ScrollViewer>

        <!-- Agent properties panel -->
        <ScrollViewer IsVisible="{Binding SelectedAgent, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Margin="14" Spacing="14">
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="ИДЕНТИФИКАТОР"/>
              <TextBox Classes="simq" Text="{Binding SelectedAgent.Id, Mode=OneWay}" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="ИМЯ"/>
              <TextBox Classes="simq" Text="{Binding SelectedAgent.Name, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="section-header" Text="ПОЗИЦИЯ"/>
              <Grid ColumnDefinitions="*,8,*">
                <NumericUpDown Grid.Column="0" Value="{Binding SelectedAgent.X, Mode=TwoWay}"/>
                <NumericUpDown Grid.Column="2" Value="{Binding SelectedAgent.Y, Mode=TwoWay}"/>
              </Grid>
            </StackPanel>
            <!-- Channels (ServiceBlock only) -->
            <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.HasChannels}">
              <TextBlock Classes="section-header" Text="КАНАЛЫ ОБСЛУЖИВАНИЯ"/>
              <NumericUpDown Value="{Binding SelectedAgent.Channels, Mode=TwoWay}"
                             Minimum="1" Maximum="1000" Increment="1" FormatString="0"/>
            </StackPanel>

            <!-- Buffer options -->
            <StackPanel Spacing="6" IsVisible="{Binding SelectedAgent.HasBufferOptions}">
              <TextBlock Classes="section-header" Text="ПОЛИТИКА"/>
              <ComboBox HorizontalAlignment="Stretch"
                        ItemsSource="{Binding SelectedAgent.AllPolicies}"
                        SelectedItem="{Binding SelectedAgent.Policy, Mode=TwoWay}"/>
              <TextBlock Classes="section-header" Text="ЁМКОСТЬ" Margin="0,6,0,0"/>
              <TextBox Classes="simq" Watermark="Infinity или число"
                       Text="{Binding SelectedAgent.Capacity, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Arrival distribution (Source / Orbit) -->
            <Border IsVisible="{Binding SelectedAgent.HasArrivalDistribution}"
                    Background="{StaticResource Panel2Brush}" CornerRadius="4" Padding="10">
              <StackPanel Spacing="8">
                <TextBlock Classes="section-header" Text="РАСПРЕДЕЛЕНИЕ ПОСТУПЛЕНИЯ"/>
                <ComboBox HorizontalAlignment="Stretch"
                          ItemsSource="{Binding SelectedAgent.ArrivalDistribution.AllKinds}"
                          SelectedItem="{Binding SelectedAgent.ArrivalDistribution.Kind, Mode=TwoWay}"/>

                <!-- Exponential: λ -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsExponential}">
                  <TextBlock Text="λ (интенсивность)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Rate, Mode=TwoWay}"
                                 Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <!-- Normal: μ, σ -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsNormal}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="μ (мат. ожидание)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Mean, Mode=TwoWay}" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="σ (ст. откл.)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Std, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- Bernoulli: p -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsBernoulli}">
                  <TextBlock Text="p (вероятность)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.P, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.###"/>
                </StackPanel>
                <!-- Beta: α, β -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsBeta}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="α" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.A, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="β" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.B, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- Binomial: p, n -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsBinomial}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="p (вероятность)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.P, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="n (испытаний)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.N, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- Poisson: λ -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsPoisson}">
                  <TextBlock Text="λ (среднее)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Rate, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <!-- Gamma: k, θ -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsGamma}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="k (форма)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.K, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="θ (масштаб)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Theta, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- Rayleigh: σ -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsRayleigh}">
                  <TextBlock Text="σ (параметр)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.Std, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <!-- Geometric: p -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsGeometric}">
                  <TextBlock Text="p (вероятность)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.P, Mode=TwoWay}" Minimum="0.0001" Maximum="1" Increment="0.05" FormatString="0.###"/>
                </StackPanel>
                <!-- Pascal: p, r -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsPascal}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="p (вероятность)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.P, Mode=TwoWay}" Minimum="0.0001" Maximum="1" Increment="0.05" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="r (успехов)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.R, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- Hypergeometric: N, n, K -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsHypergeometric}">
                  <Grid ColumnDefinitions="*,6,*,6,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="N (совокупн.)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.BigN, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="n (выборка)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.N, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Text="K (успешных)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.BigK, Mode=TwoWay}" Minimum="0" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- F: d1, d2 -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsF}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="d₁ (ст. свободы)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.A, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="d₂ (ст. свободы)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.B, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <!-- T: ν -->
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ArrivalDistribution.IsT}">
                  <TextBlock Text="ν (степени свободы)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ArrivalDistribution.A, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                </StackPanel>

                <TextBlock Text="{Binding SelectedAgent.ArrivalDistribution.Summary}"
                           Classes="mono dim" FontSize="11"/>
              </StackPanel>
            </Border>

            <!-- Service distribution (ServiceBlock) -->
            <Border IsVisible="{Binding SelectedAgent.HasServiceDistribution}"
                    Background="{StaticResource Panel2Brush}" CornerRadius="4" Padding="10">
              <StackPanel Spacing="8">
                <TextBlock Classes="section-header" Text="РАСПРЕДЕЛЕНИЕ ОБСЛУЖИВАНИЯ"/>
                <ComboBox HorizontalAlignment="Stretch"
                          ItemsSource="{Binding SelectedAgent.ServiceDistribution.AllKinds}"
                          SelectedItem="{Binding SelectedAgent.ServiceDistribution.Kind, Mode=TwoWay}"/>

                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsExponential}">
                  <TextBlock Text="λ (интенсивность)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Rate, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsNormal}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="μ" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Mean, Mode=TwoWay}" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="σ" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Std, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsBernoulli}">
                  <TextBlock Text="p (вероятность)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.P, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.###"/>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsBeta}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="α" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.A, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="β" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.B, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsBinomial}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="p" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.P, Mode=TwoWay}" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="n" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.N, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsPoisson}">
                  <TextBlock Text="λ (среднее)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Rate, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsGamma}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="k (форма)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.K, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="θ (масштаб)" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Theta, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.###"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsRayleigh}">
                  <TextBlock Text="σ" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.Std, Mode=TwoWay}" Minimum="0.0001" Increment="0.1" FormatString="0.####"/>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsGeometric}">
                  <TextBlock Text="p" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.P, Mode=TwoWay}" Minimum="0.0001" Maximum="1" Increment="0.05" FormatString="0.###"/>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsPascal}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="p" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.P, Mode=TwoWay}" Minimum="0.0001" Maximum="1" Increment="0.05" FormatString="0.###"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="r" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.R, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsHypergeometric}">
                  <Grid ColumnDefinitions="*,6,*,6,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="N" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.BigN, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="n" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.N, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                      <TextBlock Text="K" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.BigK, Mode=TwoWay}" Minimum="0" Increment="1" FormatString="0"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsF}">
                  <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="d₁" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.A, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <TextBlock Text="d₂" Classes="dim" FontSize="11"/>
                      <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.B, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="4" IsVisible="{Binding SelectedAgent.ServiceDistribution.IsT}">
                  <TextBlock Text="ν (степени свободы)" Classes="dim" FontSize="11"/>
                  <NumericUpDown Value="{Binding SelectedAgent.ServiceDistribution.A, Mode=TwoWay}" Minimum="1" Increment="1" FormatString="0.##"/>
                </StackPanel>

                <TextBlock Text="{Binding SelectedAgent.ServiceDistribution.Summary}"
                           Classes="mono dim" FontSize="11"/>
              </StackPanel>
            </Border>

            <!-- Sink: nothing to configure -->
            <Border IsVisible="{Binding SelectedAgent.IsSink}"
                    Background="{StaticResource Panel2Brush}" CornerRadius="4" Padding="10">
              <TextBlock Text="Сток принимает заявки и завершает их." Classes="dim" FontSize="11"
                         TextWrapping="Wrap"/>
            </Border>

            <Border Background="{StaticResource Panel2Brush}" CornerRadius="4" Padding="10">
              <StackPanel Spacing="4">
                <TextBlock Classes="section-header" Text="ИТОГО"/>
                <TextBlock Text="{Binding SelectedAgent.ParamsSummary}" Classes="mono" FontSize="12"/>
              </StackPanel>
            </Border>
            <Button Classes="secondary" HorizontalAlignment="Stretch" Content="🗑  Удалить агент"
                    Command="{Binding DeleteAgentCommand}" CommandParameter="{Binding SelectedAgent}"/>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
