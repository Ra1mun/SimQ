<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimQ.Client.ViewModels"
             xmlns:m="using:SimQ.Client.Models"
             xmlns:conv="using:SimQ.Client.Converters"
             x:Class="SimQ.Client.Views.TasksView"
             x:DataType="vm:MainViewModel"
             Name="HistoryRoot">
  <Grid Margin="20" RowDefinitions="Auto,*">
    <Border Grid.Row="0" Classes="card" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Classes="section-header" Text="ИСТОРИЯ ЗАПУСКОВ"/>
          <TextBlock Text="Все запуски моделирования" Classes="h2"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <ComboBox Classes="simq" SelectedIndex="0" Width="160">
            <ComboBoxItem Content="Все статусы"/>
            <ComboBoxItem Content="Завершённые"/>
            <ComboBoxItem Content="С ошибкой"/>
          </ComboBox>
          <TextBox Classes="simq" Watermark="Поиск..." Width="200"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="card" Padding="0">
      <DockPanel>
        <Grid DockPanel.Dock="Top" Background="{StaticResource Panel2Brush}"
              ColumnDefinitions="160,*,140,120,100,80">
          <TextBlock Grid.Column="0" Text="ID"        Classes="section-header" Margin="14,10"/>
          <TextBlock Grid.Column="1" Text="ЗАДАЧА"    Classes="section-header" Margin="0,10"/>
          <TextBlock Grid.Column="2" Text="ВРЕМЯ"     Classes="section-header" Margin="0,10"/>
          <TextBlock Grid.Column="3" Text="ИТЕРАЦИЙ"  Classes="section-header" Margin="0,10"/>
          <TextBlock Grid.Column="4" Text="СТАТУС"    Classes="section-header" Margin="0,10"/>
          <TextBlock Grid.Column="5" Text=""          Margin="0,10,14,10"/>
        </Grid>
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding RunHistory}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:RunRecord">
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                  <Grid ColumnDefinitions="160,*,140,120,100,80">
                    <TextBlock Grid.Column="0" Text="{Binding Id}" Classes="mono" FontSize="11" Margin="14,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding ProblemName}" FontWeight="SemiBold" FontSize="12"/>
                      <TextBlock Text="{Binding Note}" Classes="dim" FontSize="11"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding StartedAt, StringFormat='dd.MM HH:mm'}" Classes="mono dim" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding Iterations, StringFormat='{}{0:N0}'}" Classes="mono" FontSize="12" VerticalAlignment="Center"/>
                    <Border Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left" Classes="badge"
                            BorderBrush="{Binding Status, Converter={x:Static conv:RunStatusToBrushConverter.Instance}}">
                      <TextBlock FontSize="10" FontWeight="SemiBold" LetterSpacing="0.8"
                                 Foreground="{Binding Status, Converter={x:Static conv:RunStatusToBrushConverter.Instance}}"
                                 Text="{Binding Status, Converter={x:Static conv:RunStatusToLabelConverter.Instance}}"/>
                    </Border>
                    <Button Grid.Column="5" Classes="toolbar" Content="…" Width="32" Margin="0,0,14,0">
                      <Button.Flyout>
                        <MenuFlyout>
                          <MenuItem Header="Открыть результаты"
                                    Command="{Binding #HistoryRoot.((vm:MainViewModel)DataContext).OpenRunResultsCommand}"
                                    CommandParameter="{Binding}"/>
                          <MenuItem Header="Удалить"
                                    Command="{Binding #HistoryRoot.((vm:MainViewModel)DataContext).DeleteRunCommand}"
                                    CommandParameter="{Binding}"/>
                        </MenuFlyout>
                      </Button.Flyout>
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
