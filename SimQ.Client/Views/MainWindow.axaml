<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimQ.Client.ViewModels"
        xmlns:v="using:SimQ.Client.Views"
        xmlns:conv="using:SimQ.Client.Converters"
        x:Class="SimQ.Client.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="SimQ — Клиент моделирования СМО"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="700"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="Full">
  <Grid RowDefinitions="32,44,Auto,*,24">

    <!-- ============== TITLE BAR (Win11 style) ============== -->
    <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Column="0" Margin="10,0,0,0" Width="22" Height="14" CornerRadius="2"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                Background="#143D5FCC">
          <TextBlock Text="ТГУ" FontSize="8" FontWeight="Bold"
                     FontFamily="{StaticResource MonoFont}"
                     Foreground="{StaticResource AccentBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     LetterSpacing="0.5"/>
        </Border>
        <TextBlock Grid.Column="1" Text="SimQ — Клиент моделирования СМО"
                   FontSize="12" FontWeight="Medium" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
          <TextBlock Text="/" Foreground="{StaticResource BorderStrongBrush}" Margin="2,0"/>
          <TextBlock Text="{Binding CurrentProblem.Name}" Classes="mono"
                     FontSize="12" Foreground="{StaticResource FgMuteBrush}"/>
        </StackPanel>
        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button Classes="caption" Content="—" Click="OnMinimize"/>
          <Button Classes="caption" Content="▢" Click="OnMaximize"/>
          <Button Classes="caption close" Content="✕" Click="OnClose"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============== APP BAR ============== -->
    <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
        <!-- Brand -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Spacing="8">
          <Border Width="22" Height="22" CornerRadius="5" Background="{StaticResource AccentBrush}">
            <TextBlock Text="∿" Foreground="White" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="SimQ" FontSize="14" FontWeight="SemiBold"/>
          <TextBlock Text="v0.4.1" Classes="mono dim" FontSize="11"/>
        </StackPanel>

        <!-- Crumbs -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0" Spacing="6">
          <TextBlock Text="Проекты" Foreground="{StaticResource FgMuteBrush}"/>
          <TextBlock Text="›" Foreground="{StaticResource FgDimBrush}"/>
          <TextBlock Text="SimQ.Core" Foreground="{StaticResource FgMuteBrush}"/>
          <TextBlock Text="›" Foreground="{StaticResource FgDimBrush}"/>
          <TextBlock Text="{Binding CurrentProblem.Name}" FontWeight="Medium"/>
          <Border Classes="badge" Margin="6,0,0,0"
                  BorderBrush="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}">
            <TextBlock FontSize="10" FontWeight="SemiBold" LetterSpacing="1"
                       Foreground="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}"
                       Text="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToLabelConverter.Instance}}"/>
          </Border>
        </StackPanel>

        <!-- Right cluster -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                    Margin="0,0,10,0" Spacing="4">
          <Button Classes="toolbar" Content="💾 Сохранить" Command="{Binding SaveCommand}"/>
          <Button Classes="toolbar" Content="⤓ Импорт"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ============== TABS ============== -->
    <Border Grid.Row="2" Background="{StaticResource Panel2Brush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Margin="8,4,0,0" Spacing="0">
        <Button Classes="tab" Classes.active="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Editor}"   Tag="Editor"   Content="◫  Редактор модели" Click="OnTabClick"/>
        <Button Classes="tab" Classes.active="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Simulate}" Tag="Simulate" Content="▶  Моделирование"   Click="OnTabClick"/>
        <Button Classes="tab" Classes.active="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Results}"  Tag="Results"  Content="📊  Результаты"      Click="OnTabClick"/>
        <Button Classes="tab" Classes.active="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Tasks}"    Tag="Tasks"    Content="⏱  История запусков" Click="OnTabClick"/>
        <Button Classes="tab" Classes.active="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Wizard}"   Tag="Wizard"   Content="＋  Новая задача"    Click="OnTabClick"/>
      </StackPanel>
    </Border>

    <!-- ============== MAIN CONTENT ============== -->
    <Panel Grid.Row="3" Background="{StaticResource BgBrush}">
      <v:EditorView   IsVisible="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Editor}"/>
      <v:SimulateView IsVisible="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Simulate}"/>
      <v:ResultsView  IsVisible="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Results}"/>
      <v:TasksView    IsVisible="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Tasks}"/>
      <v:WizardView   IsVisible="{Binding Screen, Converter={x:Static conv:EqualsParameterConverter.Instance}, ConverterParameter=Wizard}"/>
    </Panel>

    <!-- ============== STATUS BAR ============== -->
    <Border Grid.Row="4" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" Margin="10,0" Spacing="14" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Ellipse Width="7" Height="7"
                   Fill="{Binding IsApiOnline, Converter={x:Static conv:BoolToOnlineBrushConverter.Instance}}"/>
          <TextBlock Text="{Binding ApiStatusText}" FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
        </StackPanel>
        <TextBlock Text="│" Foreground="{StaticResource BorderStrongBrush}"/>
        <TextBlock Text="{Binding CurrentProblem.Id}" Classes="mono dim" FontSize="11"/>
        <TextBlock Text="│" Foreground="{StaticResource BorderStrongBrush}"/>
        <TextBlock FontSize="11" Foreground="{StaticResource FgMuteBrush}">
          <Run Text="Агентов: "/>
          <Run Text="{Binding CurrentProblem.AgentCount}" FontWeight="SemiBold"/>
          <Run Text="    Связей: "/>
          <Run Text="{Binding CurrentProblem.EdgeCount}" FontWeight="SemiBold"/>
        </TextBlock>
        <TextBlock Text="" Width="0"/>
        <TextBlock HorizontalAlignment="Right" Margin="200,0,0,0"
                   Text="{Binding ScreenLabel, StringFormat='Экран: {0}'}"
                   FontSize="11" Foreground="{StaticResource FgMuteBrush}"/>
      </StackPanel>
    </Border>

    <!-- Tweaks panel overlay -->
    <Border Grid.Row="3" IsVisible="{Binding TweaksOpen}"
            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20"
            Width="260" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8"
            BoxShadow="0 16 40 0 #33000000">
      <StackPanel>
        <Border Background="{StaticResource Panel2Brush}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                CornerRadius="8,8,0,0">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="⚙ Tweaks" FontWeight="SemiBold" FontSize="12"/>
            <Button Grid.Column="2" Classes="icon" Content="✕" Width="22" Height="22"
                    Command="{Binding ToggleTweaksCommand}"/>
          </Grid>
        </Border>
        <StackPanel Margin="12">
          <TextBlock Classes="section-header" Text="АКЦЕНТНЫЙ ЦВЕТ" Margin="0,0,0,8"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Width="30" Height="30" CornerRadius="6" Background="#3D5FCC" BorderThickness="0"
                    Command="{Binding SetAccentCommand}" CommandParameter="250"/>
            <Button Width="30" Height="30" CornerRadius="6" Background="#2D8A4F" BorderThickness="0"
                    Command="{Binding SetAccentCommand}" CommandParameter="155"/>
            <Button Width="30" Height="30" CornerRadius="6" Background="#C99A2E" BorderThickness="0"
                    Command="{Binding SetAccentCommand}" CommandParameter="70"/>
            <Button Width="30" Height="30" CornerRadius="6" Background="#C53030" BorderThickness="0"
                    Command="{Binding SetAccentCommand}" CommandParameter="25"/>
            <Button Width="30" Height="30" CornerRadius="6" Background="#9447A6" BorderThickness="0"
                    Command="{Binding SetAccentCommand}" CommandParameter="320"/>
          </StackPanel>
          <TextBlock Margin="0,12,0,4" FontSize="10.5" Foreground="{StaticResource FgDimBrush}">
            <Run Text="Оттенок: "/><Run Text="{Binding AccentHue}" FontFamily="{StaticResource MonoFont}"/><Run Text="°"/>
          </TextBlock>
          <Slider Minimum="0" Maximum="360" Value="{Binding AccentHue, Mode=TwoWay}"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Toast -->
    <Border Grid.Row="3" IsVisible="{Binding HasToast}"
            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"
            Background="{StaticResource FgBrush}" CornerRadius="6" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="✓" Foreground="White"/>
        <TextBlock Text="{Binding Toast}" Foreground="White" FontSize="12" FontWeight="Medium"/>
      </StackPanel>
    </Border>

  </Grid>
</Window>
