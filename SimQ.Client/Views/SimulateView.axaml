<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimQ.Client.ViewModels"
             xmlns:m="using:SimQ.Client.Models"
             xmlns:conv="using:SimQ.Client.Converters"
             x:Class="SimQ.Client.Views.SimulateView"
             x:DataType="vm:MainViewModel">
  <Grid ColumnDefinitions="280,*">

    <!-- ============== LEFT SIDEBAR: ПАРАМЕТРЫ ЗАПУСКА ============== -->
    <Border Grid.Column="0"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">

        <!-- Bottom: launch button -->
        <Border DockPanel.Dock="Bottom" Padding="14,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
          <Button Classes="primary" HorizontalAlignment="Stretch" Height="36"
                  FontSize="13" FontWeight="SemiBold"
                  Content="▶  Запустить моделирование"
                  Command="{Binding StartSimulationCommand}"
                  IsEnabled="{Binding !IsRunning}"/>
        </Border>

        <!-- Top: header -->
        <Border DockPanel.Dock="Top" Padding="14,12,14,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <StackPanel Spacing="2">
            <TextBlock Classes="section-header" Text="ПАРАМЕТРЫ ЗАПУСКА"/>
            <TextBlock Classes="dim" FontSize="11" Text="Настройка сессии моделирования"/>
          </StackPanel>
        </Border>

        <!-- Body: scrollable settings -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="14,12" Spacing="12">

            <!-- Task / id -->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,2">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Задача"
                         Classes="dim" FontSize="11" Margin="0,0,8,4"/>
              <TextBlock Grid.Row="0" Grid.Column="1"
                         Text="{Binding CurrentProblem.Name}"
                         FontSize="12" FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="ID задачи"
                         Classes="dim" FontSize="11" Margin="0,0,8,0"/>
              <TextBlock Grid.Row="1" Grid.Column="1"
                         Text="{Binding CurrentProblem.Model.Id}"
                         Classes="mono" FontSize="11"/>
            </Grid>

            <!-- Iterations -->
            <StackPanel Spacing="4">
              <TextBlock Text="Число итераций" Classes="dim" FontSize="11"/>
              <NumericUpDown Value="{Binding Iterations, Mode=TwoWay}"
                             Minimum="1000" Increment="1000"
                             FormatString="0"
                             HorizontalContentAlignment="Center"/>
            </StackPanel>

            <!-- Model time -->
            <StackPanel Spacing="4">
              <TextBlock Text="Время модели (усл.ед.)" Classes="dim" FontSize="11"/>
              <NumericUpDown Value="{Binding ModelTime, Mode=TwoWay}"
                             Minimum="100" Increment="1000"
                             FormatString="0"
                             HorizontalContentAlignment="Center"/>
            </StackPanel>

            <!-- Seed -->
            <StackPanel Spacing="4">
              <TextBlock Text="Seed (Random)" Classes="dim" FontSize="11"/>
              <NumericUpDown Value="{Binding Seed, Mode=TwoWay}"
                             FormatString="0"
                             HorizontalContentAlignment="Center"/>
            </StackPanel>

            <!-- Flags -->
            <StackPanel Spacing="6" Margin="0,4,0,0">
              <CheckBox FontSize="12" Content="Собирать покадровую статистику"
                        IsChecked="{Binding CollectStepStats, Mode=TwoWay}"/>
              <CheckBox FontSize="12" Content="Сохранять логи заявок"
                        IsChecked="{Binding SaveRequestLogs, Mode=TwoWay}"/>
              <CheckBox FontSize="12" Content="Экспорт в CSV по завершении"
                        IsChecked="{Binding ExportCsvOnFinish, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Endpoint -->
            <StackPanel Spacing="6" Margin="0,8,0,0">
              <TextBlock Classes="section-header" Text="ЭНДПОИНТ"/>
              <Border Background="{StaticResource Panel2Brush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="4" Padding="8,6">
                <StackPanel Spacing="3">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="2" Padding="4,1">
                      <TextBlock Text="POST" Classes="mono" FontSize="10" FontWeight="Bold"
                                 Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                    <TextBlock Text="/Tasks/task" Classes="mono" FontSize="11"/>
                  </StackPanel>
                  <TextBlock Classes="mono dim" FontSize="11">
                    <Run Text="taskId: "/><Run Text="{Binding EndpointTaskIdLabel}"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ============== MAIN AREA ============== -->
    <ScrollViewer Grid.Column="1">
      <StackPanel Margin="24,20" Spacing="14">

        <!-- Header: title + run id + draft badge -->
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="Моделирование" Classes="h2"/>
            <TextBlock Classes="mono dim" FontSize="12" VerticalAlignment="Center">
              <Run Text="run "/><Run Text="{Binding RunId}"/>
            </TextBlock>
          </StackPanel>
          <Border Grid.Column="1" Classes="badge"
                  BorderBrush="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}">
            <TextBlock FontSize="10" FontWeight="SemiBold" LetterSpacing="1"
                       Foreground="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToBrushConverter.Instance}}"
                       Text="{Binding CurrentProblem.Status, Converter={x:Static conv:ProblemStatusToLabelConverter.Instance}}"/>
          </Border>
        </Grid>

        <!-- Progress card -->
        <Border Classes="card">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Прогресс" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Classes="mono dim" FontSize="12" Text="{Binding IterationsLabel}"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Classes="mono"
                         FontSize="22" FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}">
                <Run Text="{Binding ProgressPercent}"/><Run Text=" %"/>
              </TextBlock>
            </Grid>
            <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}"
                         Height="8" CornerRadius="4"
                         Background="{StaticResource Panel2Brush}"
                         Foreground="{StaticResource AccentBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

            <!-- 4 metric tiles -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
              <Border Grid.Column="0" Margin="0,0,6,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="ПРОШЛО"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding ElapsedLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Margin="3,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="ОСТАЛОСЬ"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding RemainingLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Margin="3,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="СР. СКОРОСТЬ"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding SpeedLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Margin="6,0,0,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="НАГРУЗКА CPU"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding CpuLoadLabel}"/>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Model preview card -->
        <Border Classes="card" Padding="14,12">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-header" Text="МОДЕЛЬ"/>

            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Height="320" ClipToBounds="True"
                    Name="SimCanvasViewport">
              <Border.Background>
                <DrawingBrush TileMode="Tile" SourceRect="0,0,24,24" DestinationRect="0,0,24,24">
                  <DrawingBrush.Drawing>
                    <GeometryDrawing>
                      <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,24,24"/>
                      </GeometryDrawing.Geometry>
                      <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource CanvasGridBrush}" Thickness="0.5"/>
                      </GeometryDrawing.Pen>
                    </GeometryDrawing>
                  </DrawingBrush.Drawing>
                </DrawingBrush>
              </Border.Background>

              <Panel ClipToBounds="True">
                <Panel Name="SimGraphCanvas"
                       Width="40000" Height="40000"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       RenderTransformOrigin="0,0"
                       ClipToBounds="False">

                  <!-- Edges layer -->
                  <ItemsControl ItemsSource="{Binding CurrentProblem.Edges}" ClipToBounds="False">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><Canvas ClipToBounds="False"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="m:Edge">
                        <Line StartPoint="{Binding StartPoint}" EndPoint="{Binding EndPoint}"
                              Stroke="{StaticResource BorderStrongBrush}" StrokeThickness="1.5"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <!-- Nodes -->
                  <ItemsControl ItemsSource="{Binding CurrentProblem.Agents}" ClipToBounds="False">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><Canvas ClipToBounds="False"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:AgentViewModel">
                        <Panel>
                          <Panel.RenderTransform>
                            <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                          </Panel.RenderTransform>

                          <!-- Node body -->
                          <Border Width="140" Height="64" CornerRadius="6"
                                  Background="White"
                                  BorderBrush="{Binding Kind, Converter={x:Static conv:AgentKindToBrushConverter.Instance}}"
                                  BorderThickness="1.5"
                                  BoxShadow="0 2 6 0 #15000000">
                            <Grid RowDefinitions="Auto,*" Margin="10,8">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="22" Height="14" CornerRadius="2"
                                        Background="{Binding Kind, Converter={x:Static conv:AgentKindToBrushConverter.Instance}}">
                                  <TextBlock Text="{Binding ShortLabel}" FontSize="8" FontWeight="Bold"
                                             FontFamily="{StaticResource MonoFont}"
                                             Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                              </StackPanel>
                              <TextBlock Grid.Row="1" Text="{Binding ParamsSummary}"
                                         Classes="mono dim" FontSize="10"
                                         VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                          </Border>

                          <!-- Left connector (input) -->
                          <Panel Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Margin="-8,0,0,0">
                            <Ellipse Width="12" Height="12" Fill="#3D5FCC" Stroke="White" StrokeThickness="2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Panel>

                          <!-- Right connector (output) -->
                          <Panel Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Margin="0,0,-8,0">
                            <Ellipse Width="12" Height="12" Fill="#3D5FCC" Stroke="White" StrokeThickness="2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="▶" FontSize="6" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0.5,0,0,0"/>
                          </Panel>
                        </Panel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Panel>
              </Panel>
            </Border>

            <!-- 4 model metric tiles -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,2,0,0">
              <Border Grid.Column="0" Margin="0,0,6,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="ПОСТУПИЛО ЗАЯВОК"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding ArrivedLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Margin="3,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="ОБСЛУЖЕНО"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Foreground="{StaticResource OkBrush}"
                             Text="{Binding ServedLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Margin="3,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="В ОЧЕРЕДИ"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Foreground="{StaticResource WarnBrush}"
                             Text="{Binding QueueLabel}"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Margin="6,0,0,0" Padding="12,10"
                      Background="{StaticResource BgBrush}"
                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                      CornerRadius="5">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-header" Text="СРЕДН. ВРЕМЯ"/>
                  <TextBlock Classes="mono" FontSize="18" FontWeight="SemiBold"
                             Text="{Binding AvgTimeLabel}"/>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Log card -->
        <Border Classes="card" Padding="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="section-header" Text="ЖУРНАЛ"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                  <Button Classes="icon" Content="🗐" ToolTip.Tip="Скопировать"/>
                  <Button Classes="icon" Content="▽"  ToolTip.Tip="Фильтр"/>
                </StackPanel>
              </Grid>
            </Border>
            <Border Background="{StaticResource LogBgBrush}" CornerRadius="0,0,6,6">
              <ScrollViewer MaxHeight="220">
                <ItemsControl ItemsSource="{Binding SimulationLogs}" Margin="12,10">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="m:SimLogEntry">
                      <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11"
                                 Foreground="{StaticResource LogFgBrush}"
                                 Margin="0,1">
                        <Run Text="["/><Run Text="{Binding Timestamp}"  Foreground="{Binding TimeBrush}"/><Run Text="] "/>
                        <Run Text="{Binding LevelLabel}"  Foreground="{Binding LevelBrush}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding Source}"      Foreground="{Binding SourceBrush}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding Message}"/>
                      </TextBlock>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </DockPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
