<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimQ.Client.ViewModels"
             xmlns:m="using:SimQ.Client.Models"
             xmlns:conv="using:SimQ.Client.Converters"
             x:Class="SimQ.Client.Views.ResultsView"
             x:DataType="vm:MainViewModel">

  <!--
       Layout:
        ┌────────────────────────────────────┬────────────────────┐
        │ Header (title + subtitle)          │  ТАБЛИЦА           │
        │ KPI strip (5 cards)                │  РЕЗУЛЬТАТОВ       │
        │ Chart                              │  (vertical scroll) │
        └────────────────────────────────────┴────────────────────┘
  -->
  <Grid Margin="20" ColumnDefinitions="*,360" RowDefinitions="Auto,Auto,*">

    <!-- ═══════════════ Header ═══════════════ -->
    <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="*,Auto" Margin="0,0,16,12">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <TextBlock Classes="h2" Text="Результаты моделирования"/>
        <TextBlock Classes="mono dim" FontSize="11"
                   VerticalAlignment="Bottom" Margin="0,0,0,4"
                   Text="{Binding ResultsSubtitle}"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="secondary" Content="⤓ Экспорт CSV"/>
    </Grid>

    <!-- ═══════════════ KPI strip ═══════════════ -->
    <Grid Grid.Row="1" Grid.Column="0"
          ColumnDefinitions="*,*,*,*,*"
          Margin="0,0,16,12"
          IsVisible="{Binding HasResults}">
      <!-- 1. mean -->
      <Border Grid.Column="0" Classes="card" Padding="16,12" Margin="0,0,8,0">
        <StackPanel Spacing="6">
          <TextBlock Classes="section-header" Text="МАТ. ОЖИДАНИЕ"/>
          <TextBlock Classes="mono" FontSize="22" FontWeight="SemiBold"
                     Text="{Binding MeanLabel}"/>
        </StackPanel>
      </Border>
      <!-- 2. variance -->
      <Border Grid.Column="1" Classes="card" Padding="16,12" Margin="4,0,4,0">
        <StackPanel Spacing="6">
          <TextBlock Classes="section-header" Text="ДИСПЕРСИЯ"/>
          <TextBlock Classes="mono" FontSize="22" FontWeight="SemiBold"
                     Text="{Binding VarianceLabel}"/>
        </StackPanel>
      </Border>
      <!-- 3. mode -->
      <Border Grid.Column="2" Classes="card" Padding="16,12" Margin="4,0,4,0">
        <StackPanel Spacing="6">
          <TextBlock Classes="section-header" Text="МОДА"/>
          <TextBlock Classes="mono" FontSize="22" FontWeight="SemiBold"
                     Text="{Binding ModeLabel}"/>
        </StackPanel>
      </Border>
      <!-- 4. median -->
      <Border Grid.Column="3" Classes="card" Padding="16,12" Margin="4,0,4,0">
        <StackPanel Spacing="6">
          <TextBlock Classes="section-header" Text="МЕДИАНА"/>
          <TextBlock Classes="mono" FontSize="22" FontWeight="SemiBold"
                     Text="{Binding MedianLabel}"/>
        </StackPanel>
      </Border>
      <!-- 5. P(X≤10) -->
      <Border Grid.Column="4" Classes="card" Padding="16,12" Margin="8,0,0,0">
        <StackPanel Spacing="6">
          <TextBlock Classes="section-header" Text="P(X ≤ 10)"/>
          <TextBlock Classes="mono" FontSize="22" FontWeight="SemiBold"
                     Text="{Binding PLeq10Label}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ═══════════════ Chart ═══════════════ -->
    <Border Grid.Row="2" Grid.Column="0" Classes="card" Padding="0" Margin="0,0,16,0"
            IsVisible="{Binding HasResults}">
      <DockPanel>
        <!-- chart header -->
        <Border DockPanel.Dock="Top" Padding="14,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Classes="section-header"
                       Text="РАСПРЕДЕЛЕНИЕ ВЕРОЯТНОСТЕЙ P(X=K)"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
              <Button Classes="toolbar" Content="⊞" ToolTip.Tip="Таблица"/>
              <Button Classes="toolbar" Content="📊" ToolTip.Tip="Гистограмма"/>
              <Button Classes="toolbar" Content="⟳" ToolTip.Tip="Обновить"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- chart body: Y-axis | plot | (x-axis labels + caption below) -->
        <Grid Margin="14,18,18,12"
              ColumnDefinitions="58,*"
              RowDefinitions="*,Auto,Auto">

          <!-- Y axis labels (5 ticks at 0, .25M, .5M, .75M, M) -->
          <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*,*,*,*">
            <TextBlock Grid.Row="0" Text="{Binding YTick4Label}"
                       Classes="mono dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-6,8,0"/>
            <TextBlock Grid.Row="1" Text="{Binding YTick3Label}"
                       Classes="mono dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-6,8,0"/>
            <TextBlock Grid.Row="2" Text="{Binding YTick2Label}"
                       Classes="mono dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-6,8,0"/>
            <TextBlock Grid.Row="3" Text="{Binding YTick1Label}"
                       Classes="mono dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,-6,8,0"/>
            <TextBlock Grid.Row="3" Text="{Binding YTick0Label}"
                       Classes="mono dim" FontSize="10"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Margin="0,0,8,-6"/>
          </Grid>

          <!-- Plot area: gridlines + bars stacked -->
          <Grid Grid.Row="0" Grid.Column="1" Height="240">
            <!-- horizontal gridlines -->
            <Grid RowDefinitions="*,*,*,*">
              <Border Grid.Row="0" BorderThickness="0,1,0,0"
                      BorderBrush="{StaticResource BorderBrush}" Opacity="0.45"/>
              <Border Grid.Row="1" BorderThickness="0,1,0,0"
                      BorderBrush="{StaticResource BorderBrush}" Opacity="0.45"/>
              <Border Grid.Row="2" BorderThickness="0,1,0,0"
                      BorderBrush="{StaticResource BorderBrush}" Opacity="0.45"/>
              <Border Grid.Row="3" BorderThickness="0,1,0,1"
                      BorderBrush="{StaticResource BorderBrush}" Opacity="0.6"/>
            </Grid>

            <!-- bars -->
            <ItemsControl ItemsSource="{Binding ResultTable}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="m:ResultRow">
                  <Border VerticalAlignment="Bottom"
                          HorizontalAlignment="Stretch"
                          Margin="3,0"
                          CornerRadius="2,2,0,0"
                          Background="#7F8FE0"
                          Height="{Binding ChartHeight}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>

          <!-- X axis labels -->
          <ItemsControl Grid.Row="1" Grid.Column="1"
                        ItemsSource="{Binding ResultTable}"
                        Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Rows="1"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:ResultRow">
                <TextBlock Text="{Binding N}"
                           Classes="mono dim" FontSize="10"
                           HorizontalAlignment="Center"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- X axis caption -->
          <TextBlock Grid.Row="2" Grid.Column="1"
                     Text="k (число заявок в системе)"
                     Classes="mono dim" FontSize="11"
                     HorizontalAlignment="Right"
                     Margin="0,6,0,0"/>
        </Grid>
      </DockPanel>
    </Border>

    <!-- ═══════════════ Right column: results table ═══════════════ -->
    <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
            Classes="card" Padding="0">
      <DockPanel>
        <!-- panel header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="14,12,10,10">
          <StackPanel Grid.Column="0" Spacing="3">
            <TextBlock Classes="section-header" Text="ТАБЛИЦА РЕЗУЛЬТАТОВ"/>
            <TextBlock Classes="dim" FontSize="11"
                       Text="Значение случайной величины / вероятность"/>
          </StackPanel>
          <Button Grid.Column="1" Classes="toolbar" Content="⤓"
                  ToolTip.Tip="Экспорт таблицы"/>
        </Grid>

        <!-- column headers -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Background="{StaticResource Panel2Brush}">
          <Grid ColumnDefinitions="58,*,*">
            <TextBlock Grid.Column="0" Text="K"      Classes="section-header" Margin="14,8,0,8"/>
            <TextBlock Grid.Column="1" Text="P(X=k)" Classes="section-header" Margin="0,8"/>
            <TextBlock Grid.Column="2" Text="CDF"    Classes="section-header" Margin="0,8"/>
          </Grid>
        </Border>

        <!-- rows -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding ResultTable}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:ResultRow">
                <Grid ColumnDefinitions="58,*,*" Height="26">
                  <TextBlock Grid.Column="0" Text="{Binding N}"
                             Margin="14,0,0,0" VerticalAlignment="Center"
                             Classes="mono dim" FontSize="12"/>
                  <TextBlock Grid.Column="1" Text="{Binding PScientific}"
                             VerticalAlignment="Center"
                             Classes="mono" FontSize="12"/>
                  <TextBlock Grid.Column="2" Text="{Binding CdfFormatted}"
                             VerticalAlignment="Center"
                             Classes="mono" FontSize="12"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ═══════════════ Empty state ═══════════════ -->
    <Border Grid.Row="2" Grid.Column="0" Classes="card"
            IsVisible="{Binding !HasResults}"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Padding="40,24" Margin="0,0,16,0">
      <TextBlock Text="Результатов по данной задаче нет"
                 Classes="h2" Opacity="0.6"/>
    </Border>

  </Grid>
</UserControl>
